generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum RequestType {
  NEED_RUB
  NEED_CFA
}

enum RequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum PaymentMethod {
  ORANGE_MONEY
  WAVE
  BANK_TRANSFER
  SBP
  OTHER
}

enum TransactionStatus {
  INITIATED
  CLIENT_SENT
  OPERATOR_VERIFIED
  OPERATOR_SENT
  COMPLETED
  DISPUTED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  RESPONDED
  RESOLVED
}

enum MessageType {
  TEXT
  IMAGE
}

enum CountryResidence {
  MALI
  RUSSIA
  OTHER
}

enum UserRole {
  CLIENT
  OPERATOR
  ADMIN
}

model User {
  id                   Int              @id @default(autoincrement())
  name                 String
  email                String           @unique
  password             String
  phoneMali            String?
  phoneRussia          String?
  countryResidence     CountryResidence @default(MALI)
  avatar               String?
  kycStatus            KycStatus        @default(VERIFIED)
  role                 UserRole         @default(CLIENT)
  isBanned             Boolean          @default(false)
  ratingAvg            Float            @default(0)
  transactionsCount    Int              @default(0)
  refreshToken         String?

  kycDocument            KycDocument?
  requests               ExchangeRequest[]
  transactionsAsClient   Transaction[]    @relation("ClientTransactions")
  transactionsAsOperator Transaction[]    @relation("OperatorTransactions")
  operatorLogs           OperatorLog[]
  reviewsGiven           Review[]         @relation("ReviewerRelation")
  reviewsReceived        Review[]         @relation("ReviewedRelation")
  disputes               Dispute[]
  messages               Message[]
  notifications          Notification[]
  notificationPrefs      NotificationPreference?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model KycDocument {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  docType     String
  frontUrl    String
  backUrl     String
  selfieUrl   String
  status      KycStatus @default(PENDING)
  reviewedBy  Int?
  reviewNote  String?
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?

  @@map("kyc_documents")
}

model PlatformAccount {
  id            Int           @id @default(autoincrement())
  method        PaymentMethod
  accountNumber String
  accountName   String
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())

  transactions Transaction[]

  @@map("platform_accounts")
}

model ExchangeRequest {
  id               Int           @id @default(autoincrement())
  clientId         Int
  client           User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type             RequestType
  amountWanted     BigInt
  currencyWanted   String
  amountToSend     BigInt
  currencyToSend   String
  /// Taux Google XOF→RUB (sans spread) au moment de la demande — affichage transparent
  rateAtRequest    Decimal       @db.Decimal(10, 6)
  commissionAmount BigInt
  paymentMethod    PaymentMethod
  phoneToSend      String
  note             String?
  status           RequestStatus @default(PENDING)
  expiresAt        DateTime
  transaction      Transaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("exchange_requests")
}

model Transaction {
  id                    Int               @id @default(autoincrement())
  requestId             Int               @unique
  request               ExchangeRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  clientId              Int
  client                User              @relation("ClientTransactions", fields: [clientId], references: [id])
  operatorId            Int
  operator              User              @relation("OperatorTransactions", fields: [operatorId], references: [id])

  amountCfa        BigInt
  amountRub        BigInt
  rate             Decimal           @db.Decimal(10, 6)
  commissionAmount BigInt

  /// Montant brut envoyé par le client sur le compte SwapTrust (devise d’envoi)
  grossAmount       BigInt?
  /// Montant net reversé à l’opérateur après commission
  netAmount         BigInt?
  commissionPercent Decimal?          @db.Decimal(5, 2)
  /// Taux Google XOF→RUB (1 XOF = googleRate RUB)
  googleRate        Decimal?          @db.Decimal(10, 6)

  platformAccountId          Int?
  platformAccount            PlatformAccount? @relation(fields: [platformAccountId], references: [id])
  platformToOperatorProofUrl   String?
  platformTransferredAt      DateTime?

  status TransactionStatus @default(INITIATED)

  clientProofUrl   String?
  operatorProofUrl String?

  /// Numéro perso opérateur (virement SwapTrust → opérateur) — non exposé au client
  operatorPaymentNumber String?
  clientReceiveNumber   String?

  operatorNote String?

  takenAt        DateTime?
  clientSentAt   DateTime?
  operatorSentAt DateTime?
  completedAt    DateTime?
  expiresAt      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages     Message[]
  review       Review?
  dispute      Dispute?
  operatorLogs OperatorLog[]

  @@index([operatorId])
  @@index([platformAccountId])
  @@map("transactions")
}

model OperatorLog {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  operatorId    Int
  operator      User        @relation(fields: [operatorId], references: [id])
  action        String
  note          String?
  createdAt     DateTime    @default(now())

  @@map("operator_logs")
}

model Message {
  id            Int         @id @default(autoincrement())
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  senderId      Int
  sender        User        @relation(fields: [senderId], references: [id])
  content       String
  type          MessageType @default(TEXT)
  attachmentUrl String?
  isRead        Boolean     @default(false)

  createdAt DateTime @default(now())

  @@map("messages")
}

model Review {
  id            Int         @id @default(autoincrement())
  transactionId Int         @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewerId    Int
  reviewer      User        @relation("ReviewerRelation", fields: [reviewerId], references: [id])
  reviewedId    Int
  reviewed      User        @relation("ReviewedRelation", fields: [reviewedId], references: [id])
  rating        Int
  comment       String?
  tags          Json?

  createdAt DateTime @default(now())

  @@map("reviews")
}

model Dispute {
  id            Int                 @id @default(autoincrement())
  transactionId Int                 @unique
  transaction   Transaction         @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  openedBy      Int
  opener        User                @relation(fields: [openedBy], references: [id])
  reason        String
  description   String
  status        DisputeStatus       @default(OPEN)
  adminId       Int?
  resolution    String?
  attachments   DisputeAttachment[]
  resolvedAt    DateTime?

  createdAt DateTime @default(now())

  @@map("disputes")
}

model DisputeAttachment {
  id        Int      @id @default(autoincrement())
  disputeId Int
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  userId    Int
  fileUrl   String

  createdAt DateTime @default(now())

  @@map("dispute_attachments")
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@map("notifications")
}

model ExchangeRate {
  id           Int      @id @default(autoincrement())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(10, 6)
  source       String   @default("google_finance")
  fetchedAt    DateTime @default(now())

  @@index([fromCurrency, toCurrency, fetchedAt])
  @@map("exchange_rates")
}

model NotificationPreference {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     Boolean  @default(true)
  sms       Boolean  @default(true)
  push      Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_preferences")
}

model AppSetting {
  key       String   @id @db.VarChar(64)
  value     String   @db.VarChar(191)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model CommissionPromo {
  id        Int      @id @default(autoincrement())
  /** Pourcentage de commission promo (ex. 1 = 1%) */
  percent   Decimal  @db.Decimal(5, 2)
  startsAt  DateTime @default(now())
  endsAt    DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@map("commission_promos")
}
