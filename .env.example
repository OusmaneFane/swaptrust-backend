NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# MySQL (ex. après `docker compose up -d`)
# allowPublicKeyRetrieval : pour MySQL 8 sans TLS, PrismaService l’ajoute si absent
DATABASE_URL="mysql://swaptrust:password@localhost:3306/swaptrust"

JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars_minimum_length
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

REDIS_HOST=localhost
REDIS_PORT=6379

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@swaptrust.com

EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://openexchangerates.org/api

UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880

PLATFORM_COMMISSION_PERCENT=2
EXCHANGE_SPREAD_PERCENT=1
