NODE_ENV=development
PORT=3001
# Écoute (0.0.0.0 = toutes interfaces, utile avec Docker). Swagger : http://127.0.0.1:PORT/api/v1/docs
# HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000
# Liens absolus dans les messages WhatsApp (sinon = FRONTEND_URL)
APP_URL=https://swaptrust.com

# notif.ml — WhatsApp (POST https://api.notif.ml/api/send, header X-API-Key)
NOTIFML_API_KEY=
NOTIFML_BASE_URL=https://api.notif.ml
# true = sandbox notif.ml (pas d’envoi réel)
NOTIFML_SANDBOX=false

# Numéro support WhatsApp affiché côté produit (optionnel)
SWAPTRUST_WHATSAPP_NUMBER=+22370000000

# MySQL — dev local (API hors Docker)
# allowPublicKeyRetrieval : pour MySQL 8 sans TLS, PrismaService l’ajoute si absent
DATABASE_URL="mysql://swaptrust:password@localhost:3306/swaptrust"

# MySQL — déploiement Docker sur le serveur (MySQL installé sur l’hôte, une base par environnement)
# Utiliser host.docker.internal (voir docker-compose.prod.yml → extra_hosts) et un user MySQL autorisé depuis le réseau Docker (ex. 'user'@'%' ou 'user'@'172.%').
# Secret GitHub ENV_FILE (staging) : base + user dédiés staging, ex. :
#   DATABASE_URL="mysql://swaptrust_staging:MOT_DE_PASSE@host.docker.internal:3306/swaptrust_staging?connection_limit=5"
# Secret GitHub ENV_FILE (production) : autre base + autre user, ex. :
#   DATABASE_URL="mysql://swaptrust_prod:MOT_DE_PASSE@host.docker.internal:3306/swaptrust_production?connection_limit=5"
# Redis sur le même serveur (hôte) depuis le conteneur :
#   REDIS_HOST=host.docker.internal

JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars_minimum_length
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Redis : OTP (auth) + cache des taux XOF/RUB. Sans serveur Redis local → warning au démarrage
# et risque de lenteur / blocage sur GET /rates/calculate si le client Redis du cache attend la connexion.
# Démarrage Redis (au choix) — à lancer depuis la racine du repo clone :
#   pnpm run docker:redis
# ou, depuis n'importe où (remplacer le chemin) :
#   docker compose -f /chemin/absolu/vers/swap-trust-backend/docker-compose.redis.yml up -d
#   pnpm run docker:redis-only   (depuis la racine du projet)
REDIS_HOST=localhost
REDIS_PORT=6379

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@swaptrust.com

EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://openexchangerates.org/api

UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880

# Commission plateforme (affichée séparément ; alias: PLATFORM_COMMISSION_PERCENT)
COMMISSION_PERCENT=2
PLATFORM_COMMISSION_PERCENT=2

# Numéros de réception SwapTrust (seed + config affichage)
SWAPTRUST_ORANGE_MONEY=+22370000000
SWAPTRUST_WAVE=+22380000000
SWAPTRUST_BANK_IBAN=ML00XXXXXXXXXXXX
SWAPTRUST_BANK_NAME="Banque de l'Habitat du Mali"

# Limites demande (centimes CFA : 500 000 = 5 000 F CFA)
MIN_AMOUNT_XOF=500000
MAX_AMOUNT_XOF=50000000

# Spread optionnel sur le cache /rates (le change métier utilise le taux Google brut + commission séparée)
EXCHANGE_SPREAD_PERCENT=1
